type Query {
  order(id: ID!): Order
  orders: [Order!]!
}

type Order {
  id: ID!
  customerName: String!
  productCode: String!
  quantity: Int!
  unitPrice: Float!
  totalPrice: Float!
  totalPriceInMinorUnits: ID!
  currency: String!
  status: String!
  s3ObjectKey: String
  createdAt: String!
  updatedAt: String!
}
